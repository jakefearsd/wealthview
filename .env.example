# Database
DB_PASSWORD=CHANGE_ME

# JWT signing secret (min 32 characters)
JWT_SECRET=CHANGE_ME

# Finnhub API key for live stock prices (optional)
FINNHUB_API_KEY=

# Enable Zillow property valuation sync (optional, defaults to false)
ZILLOW_ENABLED=false

# Super admin password
SUPER_ADMIN_PASSWORD=CHANGE_ME

# Backup retention in days (optional, defaults to 14)
BACKUP_RETENTION_DAYS=14

# CORS origin (optional, leave empty when served same-origin via Cloudflare Tunnel)
CORS_ORIGIN=

# Port the app listens on (optional, defaults to 80)
APP_PORT=80
